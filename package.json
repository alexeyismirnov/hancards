{
  "name": "hancards",
  "version": "1.0.0",
  "description": "HànCards - A Chinese character learning platform",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend && npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "start": "npm run start --workspace=backend",
    "start:frontend": "npm run preview --workspace=frontend",
    "lint": "npm run lint --workspaces",
    "db:generate": "npm run db:generate --workspace=backend",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace=backend",
    "clean": "rm -rf node_modules frontend/node_modules backend/node_modules && rm -rf frontend/dist backend/dist"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "engines": {
    "node": ">=18.0.0 <23.0.0"
  }
}
